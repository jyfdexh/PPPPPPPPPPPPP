def set_task_pause_state(task_id: str, paused: bool) -> dict[str, Any]:
    safe_task_id = normalize_task_id(task_id)
    if not safe_task_id:
        raise HTTPException(status_code=400, detail="taskId йҸҚз…ҺзҙЎж¶“е¶Ҷо„ңзәӯ?)
    with TASK_CONTROLLERS_LOCK:
        controller = TASK_CONTROLLERS.get(safe_task_id)
    if controller is None:
        raise HTTPException(status_code=404, detail="жө иҜІе§ҹж¶“е¶…з“ЁйҚҰг„ҰеһЁе®ёиҢ¬зІЁйҸү?)
    if paused:
        controller.pause()
    else:
        controller.resume()
    return {"ok": True, "task_id": safe_task_id, "paused": controller.is_paused()}


def terminate_task(task_id: str) -> dict[str, Any]:
    safe_task_id = normalize_task_id(task_id)
    if not safe_task_id:
        raise HTTPException(status_code=400, detail="taskId йҸҚз…ҺзҙЎж¶“е¶Ҷо„ңзәӯ?)
    with TASK_CONTROLLERS_LOCK:
